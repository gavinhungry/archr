#!/usr/bin/env node

/**
 * archr - Search for and download Arch Linux packages
 * https://github.com/gavinhungry/archr
 */

(() => {
  'use strict';

  const pjson = require('../package.json');
  const archr = require('../lib/archr.js');

  const fs = require('node:fs/promises');
  const path = require('node:path');
  const { styleText } = require('node:util');

  let red = str => styleText('red', str);

  let download = async (uri, dir) => {
    let response = await fetch(uri);
    if (!response.ok) {
      let err = new Error(response.statusText || 'Request failed');
      err.statusCode = response.status;
      throw err;
    }
    let buf = Buffer.from(await response.arrayBuffer());
    let filename = path.basename(new URL(uri).pathname);
    await fs.writeFile(path.join(dir, filename), buf);
  };

  /**
   * Split repo and pkgname apart
   *
   * @param {String} pkgname - package name or repo/package
   * @return {Object} { repo, pkgname }
   */
  let split = pkgname => {
    let repo = null;

    let s = pkgname.split('/');
    if (s.length > 1) {
      repo = s[0];
      pkgname = s[1];
    }

    return {
      repo: repo,
      pkgname: pkgname
    };
  };

  let cli = {
    /**
     * Exit now
     *
     * @param {Number} [code] - exit code
     * @param {String} [msg] - exit message
     */
    exit: (code, msg) => {
      code = code || 0;

      if (msg) {
        let output = (code === 0) ? 'log' : 'error';
        console[output](msg);
      }

      process.exit(code);
    },

    /**
     * Print search results
     *
     * @param {String} query
     * @return {Promise}
     */
    search: async query => {
      let opts = app.opts();
      let { pkgname, repo } = split(query);

      let results = await archr.search(pkgname, repo, opts.arch).catch(() => {
        cli.exit(1, 'Search error');
      });

      results.map(pkg => {
        let line = `${pkg.repo}/${pkg.pkgname}`;

        if (!opts.quiet) {
          line += ` ${pkg.pkgver}-${pkg.pkgrel}`;
        }

        return line;
      }).sort().forEach(line => {
        console.log(line);
      });
    },

    /**
     * Download a file
     *
     * @param {String} uri - file URI
     * @return {Promise}
     */
    download: uri => {
      let opts = app.opts();
      console.log('Downloading', uri);

      return download(uri, opts.dir).catch(err => {
        console.error(red(`Error: ${err.message} [${err.code || err.statusCode}]`));
      });
    },

    /**
     * Download multiple files
     *
     * @param {Array.<String>} uris - file URIs
     * @return {Promise} to resolve to saved paths
     */
    downloads: async uris => {
      for (let uri of uris) {
        await cli.download(uri);
      }
    }
  };

  let app = require('commander').program
    .version(pjson.version)
    .option('-a, --arch <arch>', `system architecture [${archr.defaults.arch}]`)
    .option('-d, --dir <dir>', 'path to save downloads', process.cwd())
    .option('-i, --ignore-cert', 'ignore certificate errors')
    .option('-s, --signatures', 'also download signature files')
    .option('-q, --quiet', 'no version output')
    .hook('preAction', cmd => {
      if (cmd.opts().ignoreCert) {
        process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
      }
    });

  app.command('search <query>').action(cli.search);

  app.command('download <pkg> [pkg...]').action((pkg, pkgs) => {
    let opts = app.opts();
    pkgs.unshift(pkg);

    let uris_p = pkgs.map(split).map(pkg => {
      return archr.uri(pkg.pkgname, pkg.repo, opts.arch).catch(() => {
        console.error(red(`Error: Could not find package [${pkg.repo || archr.defaults.repo}/${pkg.pkgname}]`));
      });
    });

    return Promise.all(uris_p).then(uris => {
      if (opts.signatures) {
        uris = uris.map(uri => {
          return [uri, `${uri}.sig`]
        }).flat();
      }

      return cli.downloads(uris.filter(Boolean));
    });
  });

  if (process.argv.length <= 2) {
    app.help();
  }

  app.parse(process.argv);
})();
